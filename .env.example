# Copy to .env.local to override settings locally (git-ignored)
# These are the defaults — only override what you need to change.

# API base path. In dev the Vite proxy forwards this to VITE_DEV_API_TARGET.
VITE_API_URL=/api/v1

# WebSocket base path. Same proxy rule applies in dev.
VITE_WS_URL=/

# Set to true only when you have no backend running and want static mock data.
VITE_USE_MOCK=false

# ── Dev-only ─────────────────────────────────────────────────────────────────
# Where the Vite proxy forwards /api and /socket.io requests in development.
# Not embedded in the build; only used by the local Vite server.
VITE_DEV_API_TARGET=http://localhost:3000
